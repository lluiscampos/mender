<node name="/com/mender/AuthenticationManager1">
  <!--
    com.mender.Authentication1:
    @short_description: Authentication API v1

    This interface lets applications authenticate with the Mender backend.
  -->

  <interface name="com.mender.Authentication1">
    <!--
      GetJwtToken:
      @token: Current JWT token

      Gets current JWT token. If no JWT token is available, error is returned.
    -->
    <method name="GetJwtToken">
      <arg name="token" direction="out" type="s">
      </arg>
    </method>
    <!--
      FetchJwtToken:
      @token: Fetch JWT token

      Instructs the Mender client to fetch the JWT tokenf rom the backend.
    -->
    <method name="FetchJwtToken">
    </method>
    <!--
      ValidJwtTokenAvailable:

      Emitted whenever a valid JWT is available in the Mender client.
    -->
    <signal name="ValidJwtTokenAvailable">
    </signal>
  </interface>
</node>
